
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores extended user information for accounts.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's preferred name."
        },
        "photoURL": {
          "type": "string",
          "description": "URL to the user's profile picture."
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "bio": {
          "type": "string",
          "description": "A short bio for the user profile."
        },
        "interests": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of selected interest categories for feed personalization."
        },
        "onboardingComplete": {
          "type": "boolean",
          "description": "Whether the user has finished the initial interest selection."
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Grants access to management features."
        },
        "walletBalance": {
          "type": "number",
          "description": "Current available funds in the user's wallet."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "email",
        "createdAt"
      ]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial record of a deposit or spend operation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "spend", "refund"] },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["completed", "failed", "pending"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "method": { "type": "string" },
        "orderId": { "type": "string" }
      }
    },
    "Submission": {
      "title": "Submission",
      "description": "A website submitted by a user for curation.",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "logoUrl": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Promotion": {
      "title": "Promotion",
      "description": "A sophisticated advertising campaign for a website.",
      "type": "object",
      "properties": {
        "promoId": { "type": "string" },
        "orderId": { "type": "string" },
        "websiteId": { "type": "string" },
        "websiteUrl": { "type": "string" },
        "websiteName": { "type": "string" },
        "objective": { "type": "string" },
        "placement": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "duration": { "type": "number" },
        "dailyBudget": { "type": "number" },
        "cost": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "scheduled", "active", "completed", "cancelled", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" }
      }
    },
    "WebsiteStats": {
      "title": "Website Stats",
      "description": "Global statistics and metadata for a website.",
      "type": "object",
      "properties": {
        "visitCount": { "type": "number" },
        "likeCount": { "type": "number" },
        "shareCount": { "type": "number" },
        "ratingSum": { "type": "number" },
        "ratingCount": { "type": "number" },
        "logoUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user profile documents."
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial history for a specific user."
    },
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "User submitted project requests."
    },
    "/websiteStats/{websiteId}": {
      "schema": "WebsiteStats",
      "description": "Global stats and cached preview metadata for a website."
    },
    "/promotions/{promoId}": {
      "schema": "Promotion",
      "description": "Digital advertising campaigns."
    }
  }
}
