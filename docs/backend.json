
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores extended user information for accounts.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's preferred name."
        },
        "photoURL": {
          "type": "string",
          "description": "URL to the user's profile picture."
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "bio": {
          "type": "string",
          "description": "A short bio for the user profile."
        },
        "interests": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of selected interest categories for feed personalization."
        },
        "onboardingComplete": {
          "type": "boolean",
          "description": "Whether the user has finished the initial interest selection."
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Grants access to management features."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "email",
        "createdAt"
      ]
    },
    "Submission": {
      "title": "Submission",
      "description": "A website submitted by a user for curation.",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "logoUrl": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "SavedWebsite": {
      "title": "Saved Website",
      "description": "Represents a website saved by a user.",
      "type": "object",
      "properties": {
        "websiteId": {
          "type": "string",
          "description": "The ID of the website."
        },
        "savedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "websiteId",
        "savedAt"
      ]
    },
    "UserInteraction": {
      "title": "User Interaction",
      "description": "Tracks an individual user's specific interaction with a website to prevent duplicates.",
      "type": "object",
      "properties": {
        "interactedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "WebsiteStats": {
      "title": "Website Stats",
      "description": "Global statistics and metadata for a website.",
      "type": "object",
      "properties": {
        "visitCount": {
          "type": "number",
          "description": "Total clicks on the 'Visit Website' button."
        },
        "likeCount": {
          "type": "number",
          "description": "Total number of users who liked the project."
        },
        "shareCount": {
          "type": "number",
          "description": "Total unique shares by authenticated users."
        },
        "ratingSum": {
          "type": "number",
          "description": "Sum of all ratings given."
        },
        "ratingCount": {
          "type": "number",
          "description": "Total number of users who rated."
        },
        "previewUrl": {
          "type": "string",
          "description": "Cached URL for the website preview image."
        },
        "logoUrl": {
          "type": "string",
          "description": "Cached URL for the website logo."
        },
        "lastPreviewUpdate": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "UserRating": {
      "title": "User Rating",
      "description": "An individual user's rating for a website.",
      "type": "object",
      "properties": {
        "rating": {
          "type": "number"
        },
        "comment": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "userDisplayName": {
          "type": "string"
        },
        "userPhotoURL": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "rating",
        "userId"
      ]
    },
    "Promotion": {
      "title": "Promotion",
      "description": "An advertising campaign for a website.",
      "type": "object",
      "properties": {
        "websiteId": { "type": "string" },
        "websiteUrl": { "type": "string" },
        "placement": { "type": "string", "enum": ["homepage", "trending", "category", "search", "editors"] },
        "duration": { "type": "number", "description": "Duration in days." },
        "cost": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "pending", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user profile documents."
    },
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "User submitted project requests."
    },
    "/users/{userId}/likedWebsites/{saveId}": {
      "schema": "SavedWebsite",
      "description": "Collection of websites bookmarked (saved) by the user."
    },
    "/users/{userId}/userLikes/{websiteId}": {
      "schema": "UserInteraction",
      "description": "Tracks if a user has liked a website to enable toggling."
    },
    "/users/{userId}/userShares/{websiteId}": {
      "schema": "UserInteraction",
      "description": "Tracks if a user has shared a website to prevent duplicate global increments."
    },
    "/websiteStats/{websiteId}": {
      "schema": "WebsiteStats",
      "description": "Global stats and cached preview metadata for a website."
    },
    "/websiteStats/{websiteId}/userRatings/{userId}": {
      "schema": "UserRating",
      "description": "Individual ratings to prevent double-voting."
    },
    "/promotions/{promoId}": {
      "schema": "Promotion",
      "description": "Digital advertising campaigns."
    }
  }
}
